# Docker image published by GitHub Actions.
IMAGE=ghcr.io/deeptgai/workspace
IMAGE_TAG=sha-16d79f5

# Public domain routed by Traefik. DNS/proxy is managed in Cloudflare.
DOMAIN=tgdeep.xyz

# Traefik reverse proxy.
TRAEFIK_IMAGE=traefik:v3.7
TRAEFIK_REPLICAS=1
TRAEFIK_NETWORK=deeptg_app
TRAEFIK_ROUTER_NAME=deeptg
TRAEFIK_SERVICE_NAME=deeptg
TRAEFIK_WEB_ENTRYPOINT=web
TRAEFIK_WEBSECURE_ENTRYPOINT=websecure
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_HTTP_PUBLISHED_PORT=80
TRAEFIK_HTTPS_PUBLISHED_PORT=443
TRAEFIK_SWARM_ENDPOINT=unix:///var/run/docker.sock
TRAEFIK_DOCKER_SOCKET=/var/run/docker.sock
TRAEFIK_CERT_RESOLVER=le
TRAEFIK_ACME_EMAIL=admin@tgdeep.xyz
TRAEFIK_ACME_STORAGE=/letsencrypt/acme.json
TRAEFIK_ACME_VOLUME=deeptg_traefik_letsencrypt
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_ACCESSLOG=true

# Swarm stack/service settings.
STACK=deeptg
WEB_INTERNAL_PORT=3000
WEB_REPLICAS=1
WORKER_REPLICAS=1

# Database.
POSTGRES_DB=deeptg
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_VOLUME=deeptg_postgres_data
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/deeptg

# Redis.
REDIS_URL=redis://redis:6379
REDIS_VOLUME=deeptg_redis_data

# Admin UI basic auth. Public snapshot routes stay open.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Telegram API credentials from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# AI provider.
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=https://your-domain.example
OPENROUTER_APP_TITLE=DeepTG
AI_MODEL=anthropic/claude-sonnet-4.5
AI_REQUEST_TIMEOUT_MS=300000
AI_REQUEST_MAX_ATTEMPTS=3

# Embeddings.
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=intfloat/multilingual-e5-large
EMBEDDINGS_BATCH_SIZE=50
EMBEDDINGS_REQUEST_TIMEOUT_MS=60000

# Telegram import defaults.
TELEGRAM_IMPORT_BATCH_SIZE=100
TELEGRAM_IMPORT_SLEEP_MS=3000
TELEGRAM_IMPORT_SINCE_DAYS=365
UI_TELEGRAM_DIALOG_LIMIT=500
UI_UPDATE_IMPORT_LIMIT=200
UI_UPDATE_COMMENT_POST_LIMIT=80
UI_UPDATE_COMMENTS_PER_POST=100
UI_FULL_IMPORT_LIMIT=500
UI_FULL_COMMENT_POST_LIMIT=100
UI_FULL_COMMENTS_PER_POST=100

# Snapshot workers.
SNAPSHOT_SECTION_WORKER_CONCURRENCY=4
SNAPSHOT_SECTION_AGENT_TIMEOUT_MS=600000
SNAPSHOT_PEOPLE_CONTEXT_LIMIT=30
SNAPSHOT_POST_SEGMENT_LIMIT=25
SNAPSHOT_POST_SEGMENT_COMMENTS_LIMIT=8
